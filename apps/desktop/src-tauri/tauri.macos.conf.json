{
  "build": {
    "beforeBuildCommand": "pnpm --dir ../.. prepare:desktop-build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1360,
        "height": 800,
        "minWidth": 360,
        "minHeight": 320,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "externalBin": [
      "binaries/qingyu-mcp"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "mimeType": "text/markdown",
        "role": "Editor"
      }
    ]
  }
}
